{
  "name": "blackbean",
  "version": "0.0.1",
  "description": "Automatic AI-powered membean bot.",
  "type": "module",
  "license": "AGPL-3.0-or-later",
  "scripts": {
    "start": "tsx ./src/ts/index.ts",
    "build": "tsc && tsc-esm-fix ./dist",
    "lint": "eslint . --ext .ts",
    "lint:fix": "run-script-os",
    "lint:fix:win32": "(ts-standard --fix >NUL 2>&1) || (eslint . --ext .ts --fix | snazzy)",
    "lint:fix:default": "(ts-standard --fix > /dev/null 2>&1) || (eslint . --ext .ts --fix | snazzy)"
  },
  "bin": {
    "blackbean": "./dist/index.js"
  },
  "exports": {
    ".": "./dist/exports.js"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "membean",
    "automembean",
    "membeaner"
  ],
  "author": "Colbster937",
  "devDependencies": {
    "@stylistic/eslint-plugin": "^5.6.1",
    "@types/node": "^25.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "run-script-os": "^1.1.6",
    "snazzy": "^9.0.0",
    "ts-standard": "^12.0.2",
    "tsc-esm-fix": "^3.1.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.49.0"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.8.1",
    "cli-progress": "^3.12.0",
    "crypto": "^1.0.1",
    "css.escape": "^1.5.1",
    "dotenv": "^17.2.3",
    "fs": "^0.0.1-security",
    "openai": "^6.10.0",
    "optimist": "^0.6.1",
    "puppeteer": "^24.32.1",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "puppeteer-extra-plugin-user-preferences": "^2.4.1",
    "tesseract.js": "^6.0.1"
  }
}
